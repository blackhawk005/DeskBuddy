// ============================================================================
// secrets.h.example  —  copy to secrets.h and fill in. secrets.h is gitignored.
// ============================================================================
#pragma once

#define WIFI_SSID  "your-ssid"
#define WIFI_PASS  "your-password"

// Password required to push over-the-air (Wi-Fi) firmware updates. Set a real one —
// anyone on your LAN who knows it can reflash the device. Leave "" to allow
// unauthenticated LAN updates (not recommended).
#define OTA_PASSWORD "change-me"

// Optional: leave empty to use the built-in romantic quote pack (fully offline).
// If set, DeskBuddy fetches from this URL and expects a JSON array of strings,
// e.g. ["quote one","quote two"]. Must be HTTPS.
#define QUOTES_URL ""

// Optional: a URL returning a plain-text message to show on the MESSAGE page.
// May contain a secret token — keep it here (gitignored), never commit it.
#define MESSAGE_URL ""
